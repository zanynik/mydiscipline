# Temporary Fastfile containing the one-off lane that creates the App Store
# Connect app entry. Once `fastlane create_new_app` has run successfully,
# this whole file (or at least the lane) can be deleted.

default_platform(:ios)

platform :ios do
  lane :create_new_app do
    # 1. Load the App Store Connect API key from the APP_STORE_CONNECT_API_KEY_*
    #    env vars (mapped in the GitHub Actions workflow from the repo secrets).
    #    This silently authenticates without prompting for a password.
    api_key = app_store_connect_api_key

    # 2. Create the app record using that authenticated session.
    produce(
      api_key: api_key,
      app_identifier: "com.mydiscipline.app",
      app_name: "MyDiscipline",
      sku: "discipline",
      team_id: "Y2CUHDBA6F"
    )
  end
end
